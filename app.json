{
  "expo": {
    "name": "Metadeal",
    "slug": "metadeal",
    "privacy": "public",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "version": "1.5.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.descala.metadeal"
    },
    "extra": {
      "eas": {
        "projectId": "b1d903bb-814e-4656-900e-04d6027ea029"
      }
    }
  }
}
