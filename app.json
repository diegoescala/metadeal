{
  "expo": {
    "name": "metadeal",
    "description": "Rental property deal analyzer",
    "slug": "metadeal",
    "version": "1.4.1",
    "orientation": "portrait",
    "primaryColor": "#cccccc",
    "privacy": "public",
    "entryPoint": "./build/index.js",
    "icon": "./assets/icon.png",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2f043e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "appStoreUrl": "https://apps.apple.com/us/app/metadeal-real-estate-analyzer/id1506517876",
      "config": {
        "googleMobileAdsAppId": "ca-app-pub-7070415808259435~8428069021"
      },
      "infoPlist": {
        "SKAdNetworkIdentifier": "cstr6suwn9.skadnetwork",
        "NSUserTrackingUsageDescription": "This app tracks how users navigate around the various functions of the app, so that we can focus on improving our users' experience."
      },
      "supportsTablet": true,
      "buildNumber": "1",
      "bundleIdentifier": "com.diegoescala.abakus"
    },
    "android": {
      "package": "com.diegoescala.abakus"
    }
  },
  "react-native-google-mobile-ads": {
    "android_app_id": "",
    "ios_app_id": "ca-app-pub-7070415808259435/9426769000"
  }
}
